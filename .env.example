# PostgreSQL connection (copy this file to .env and fill in real values)
POSTGRES_USER=md_user
POSTGRES_PASSWORD=change_me
POSTGRES_DB=md_data
POSTGRES_HOST=localhost
# Host port for the Postgres container. 5433 avoids clashing with a native
# PostgreSQL that may already use the default 5432 on your machine.
POSTGRES_PORT=5433
