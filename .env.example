# PostgreSQL connection (copy this file to .env and fill in real values)
POSTGRES_USER=md_user
POSTGRES_PASSWORD=change_me
POSTGRES_DB=md_data
POSTGRES_HOST=localhost
# Host port for the Postgres container. 5433 avoids clashing with a native
# PostgreSQL that may already use the default 5432 on your machine.
POSTGRES_PORT=5433

# Airflow metadata database (separate from the data warehouse above)
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=change_me
AIRFLOW_DB_NAME=airflow

# Airflow runtime
AIRFLOW_UID=50000
# Generate one with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=change_me
